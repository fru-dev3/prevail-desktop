{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prevail",
  "version": "0.3.109",
  "identifier": "sh.prevail.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && bash scripts/prepare-sidecar.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prevail",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#faf8f1",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://github.com https://objects.githubusercontent.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fru-dev3/prevail-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBRTIyRTJENzNEM0MyRkIKUldUN3d0TnpMUzdpMm51aTUwV3Y3d0NaN2owSnhrLzdtS2dzUm8weURrUHAwRWN1TnR1MGNndnYK"
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "prevail"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/prevail"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/connectors/catalog.json",
      "resources/connectors/logos.json",
      "resources/connectors/cli_providers.json",
      "resources/sample-vault/**/*",
      "resources/skill-packs/**/*",
      "resources/node_modules/playwright-core/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist"
    }
  }
}
