{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prevail",
  "version": "0.4.2",
  "identifier": "sh.prevail.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && bash scripts/prepare-sidecar.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prevail",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#faf8f1"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; connect-src 'self' ipc: http://ipc.localhost https://fonts.googleapis.com https://fonts.gstatic.com https://api.github.com https://github.com https://objects.githubusercontent.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/fru-dev3/prevail-desktop/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCOEJCNDBFRkVEQzk1QzMKUldURGxkeitEclNMNjR5dWlBbDZsc0djUnB0RzJBaHphVTJuTUpUV3Nhc0JlUTFRM3A2UFhSd24K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/prevail"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/automation/playwright_runner.js",
      "resources/automation/recipes.json",
      "resources/sample-vault/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist"
    }
  }
}
