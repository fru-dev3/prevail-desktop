{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prevail",
  "version": "0.2.5",
  "identifier": "sh.prevail.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prevail",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#faf8f1"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
