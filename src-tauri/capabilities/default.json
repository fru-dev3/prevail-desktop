{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window — vault scanning, CLI spawning, benchmark file IO",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "dialog:default",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:default",
    "notification:default",
    "process:allow-restart",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "which", "cmd": "which", "args": true },
        { "name": "curl", "cmd": "curl", "args": true },
        { "name": "open", "cmd": "open", "args": true },
        { "name": "xdg-open", "cmd": "xdg-open", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "codex", "cmd": "codex", "args": true },
        { "name": "agy", "cmd": "agy", "args": true },
        { "name": "ollama", "cmd": "ollama", "args": true }
      ]
    }
  ]
}
