<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened runtime is mandatory for notarization; Tauri enables it.
       allow-jit is required for the WKWebView JS engine's JIT. We deliberately
       do NOT grant allow-unsigned-executable-memory: on Apple Silicon WKWebView
       allow-jit alone suffices, and dropping the unsigned-W^X exemption keeps
       full hardened-runtime memory protection (smaller blast radius if a
       memory-corruption bug is ever found). Verify the webview renders. -->
  <key>com.apple.security.cs.allow-jit</key><true/>
  <!-- The bundled `prevail` engine sidecar spawns a browser-automation helper
       (Chromium, auto-downloaded to Application Support — NOT bundled, so its
       helper apps never need deep-signing/notarizing). For the engine to find
       it we pass PLAYWRIGHT_BROWSERS_PATH across the spawn boundary; under the
       hardened runtime that DYLD/env var is stripped unless this is set. Scoped
       to the app; the downloaded Chromium runs as its own non-notarized process
       (Gatekeeper allows it because it is fetched without the quarantine flag). -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key><true/>
</dict>
</plist>
