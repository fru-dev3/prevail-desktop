<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required so macOS can show the microphone permission prompt (the app
       crashes on mic access without it). Used by Quick Capture's voice note
       transcription. Tauri merges this into the generated Info.plist. -->
  <key>NSMicrophoneUsageDescription</key>
  <string>Prevail uses the microphone to capture voice notes, transcribing your speech to text.</string>
</dict>
</plist>
