# Prevail desktop build-time config. Copy to .env for local builds.
#
# These are CLIENT-side keys (safe to embed; write/ingest-only). For the OFFICIAL
# build, CI injects them from GitHub secrets (see .github/workflows/release.yml),
# so .env itself is NOT committed - a fork won't send telemetry to the upstream
# project. For a local build, paste your own keys (or leave blank to disable).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=
